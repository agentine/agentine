{
  "name": "@agentine/pyre",
  "version": "0.1.0",
  "description": "Drop-in logging framework replacing log4js — Log4j-inspired API, category hierarchy, appenders, layouts, clustering, TypeScript-first, zero deps, ESM+CJS",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentine/pyre.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./compat/log4js": {
      "import": "./dist/esm/compat/log4js.js",
      "require": "./dist/cjs/compat/log4js.js",
      "types": "./dist/esm/compat/log4js.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
